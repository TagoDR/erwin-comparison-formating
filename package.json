{
  "name": "erwin-comparison-formating",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode standalone && vite build --mode monkey",
    "build:standalone": "vite build --mode standalone",
    "build:monkey": "vite build --mode monkey",
    "preview": "vite preview",
    "prettier": "prettier --write '**/*.{md,html,svg}'",
    "biome": " biome check --write .",
    "gen:sample": "node --loader ts-node/esm scripts/generate-sample-html.ts"
  },
  "dependencies": {
    "@nanostores/lit": "^0.2.3",
    "bootflat": "^2.0.4",
    "lit": "^3.3.2",
    "lit-translate": "^2.0.1",
    "nanostores": "^1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "userscript-metadata-generator": "^0.2.4",
    "vite": "^8.0.8",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-svg-loader": "^5.1.1"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.svg",
        "options": {
          "parser": "html"
        }
      }
    ],
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100,
    "arrowParens": "avoid",
    "endOfLine": "crlf",
    "singleAttributePerLine": true
  }
}
